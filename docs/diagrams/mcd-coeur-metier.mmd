    DEMANDE_LIVRAISON ||--o| ARRET_LIVRAISON   : "realise"
    ARRET_LIVRAISON   ||--o| PREUVE_LIVRAISON  : "atteste"
    PLAN              |o--o{ EVENEMENT         : "impacte"
    MISSION           |o--o{ EVENEMENT         : "impacte"
    DEMANDE_LIVRAISON |o--o{ EVENEMENT         : "impacte"
