# CofICab Platform Environment Configuration
# Copy this file to .env and update values for your environment

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coficab_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=coficab_db

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Backend API ===
BACKEND_API_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Agent Configuration ===

# Agent 1: Watchdog
WATCH_DIRECTORY=./shared_folder

# Agent 3: Alert Monitor
MONITOR_INTERVAL=10

# Agent 4: TFM Tracker
TFM_API_URL=http://tfm-api:8080
POLL_INTERVAL=300

# === Copilot (Optiroute LLM assistant) ===
# The in-app Dispatch Copilot talks to any OpenAI-compatible chat endpoint.
# Default target is Groq (free, fast, Llama 3.3 70B). Without a key the copilot
# input is disabled and /api/copilot/chat returns 503.
# Provide ONE of: GROQ_API_KEY, COPILOT_API_KEY, or OPENAI_API_KEY.
GROQ_API_KEY=
# Optional overrides (defaults shown):
# COPILOT_MODEL=llama-3.3-70b-versatile
# COPILOT_BASE_URL=https://api.groq.com/openai/v1
# COPILOT_MAX_TOKENS=1024
# COPILOT_MAX_TOOL_ITERATIONS=6
#
# To use Anthropic/OpenAI/Together/Ollama instead, point COPILOT_BASE_URL +
# COPILOT_MODEL at that provider and set the matching key.

# === Environment ===
# Set to "production" in real deployments. When production, the app FAILS FAST
# if JWT_SECRET is a placeholder or DATABASE_URL is unset / uses default creds,
# and anonymous access to protected routes is rejected (no dev fallback).
APP_ENV=development

# === Security ===
# In production, replace with a strong unique value from your secret manager.
JWT_SECRET=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Enforce auth on protected routes in non-production environments (optional).
REQUIRE_AUTH=0

# === Logging ===
LOG_LEVEL=INFO
